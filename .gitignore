# Files to ignore when considering what GIT should commit.

# Visual Studio
*.suo
*.user
*.sln.docstates
*.obj
*.obj.enc
*.pch
*.tlog
*.log
*.scc
*.exp
*.ilk
*.lastbuildstate
vc100.pdb
vc120.pdb
ipch
*.sdf
*.opensdf
*.idb
*.vcxproj
*.vcxproj.filters
*.sln
*.FileListAbsolute.txt
.vs/

# CodeLite
*.project

# OSX/Linux build products
*.mak
*.mak.vpc_crc
*.xcodeproj/
obj*/
!devtools/*.mak
!utils/smdlexp/smdlexp.mak

# VPC
*.vcxproj.vpc_crc
*.vpc.sentinel

# Compile products
*.exe
*.dll
*.lib
*.pdb
*.so
*.so.dbg
*.dylib
*.dylib.dSYM/
!devtools/bin/*.exe
!devtools/bin/*.dll

# files generated by running a mod
config.cfg

# shader files
*.tmp

# Local build/run artifacts (not committed)
/dist/
/tools/steamcmd/
/build/.cache/
/build/last-build.log

# MSBuild intermediate output dirs produced by the v143 build
**/Release/
**/Release_tf_mod/
**/Debug/
**/Debug_tf_mod/
